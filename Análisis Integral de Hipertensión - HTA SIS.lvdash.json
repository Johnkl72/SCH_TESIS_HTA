{
  "datasets": [
    {
      "name": "hta_metrics",
      "displayName": "HTA Metrics",
      "config": {
        "version": "1.1",
        "source": "workspace.hta_sis.ua_hta_gold_ml",
        "dimensions": [
          {
            "name": "codigo_anonimizado",
            "expr": "CODIGO_ANONIMIZADO"
          },
          {
            "name": "sexo",
            "expr": "SEXO"
          },
          {
            "name": "edad",
            "expr": "EDAD"
          },
          {
            "name": "grupo_edad",
            "expr": "CASE \n  WHEN EDAD < 18 THEN '0-17'\n  WHEN EDAD < 30 THEN '18-29'\n  WHEN EDAD < 45 THEN '30-44'\n  WHEN EDAD < 60 THEN '45-59'\n  WHEN EDAD < 75 THEN '60-74'\n  ELSE '75+'\nEND\n"
          },
          {
            "name": "nivel_eess",
            "expr": "NIVEL_EESS"
          },
          {
            "name": "servicio_prestacional",
            "expr": "SERVICIO_PRESTACIONAL"
          },
          {
            "name": "tipo_personal_salud",
            "expr": "TIPO_PERSONAL_SALUD"
          },
          {
            "name": "target_destino",
            "expr": "TARGET_DESTINO"
          },
          {
            "name": "diagnostico_principal",
            "expr": "DIAGNOSTICO_PRINCIPAL"
          },
          {
            "name": "pres_art_sistolica",
            "expr": "PRES_ART_SISTOLICA"
          },
          {
            "name": "pres_art_diastolica",
            "expr": "PRES_ART_DIASTOLICA"
          },
          {
            "name": "sist_anterior",
            "expr": "SIST_ANTERIOR"
          },
          {
            "name": "diast_anterior",
            "expr": "DIAST_ANTERIOR"
          },
          {
            "name": "dias_desde_ultima_cita",
            "expr": "DIAS_DESDE_ULTIMA_CITA"
          },
          {
            "name": "cant_tipos_medicamentos",
            "expr": "CANT_TIPOS_MEDICAMENTOS"
          },
          {
            "name": "costo_total_medicamentos",
            "expr": "COSTO_TOTAL_MEDICAMENTOS"
          },
          {
            "name": "costo_total_insumos",
            "expr": "COSTO_TOTAL_INSUMOS"
          }
        ],
        "measures": [
          {
            "name": "total_pacientes",
            "expr": "COUNT(DISTINCT CODIGO_ANONIMIZADO)"
          },
          {
            "name": "prom_sistolica",
            "expr": "AVG(PRES_ART_SISTOLICA)"
          },
          {
            "name": "prom_diastolica",
            "expr": "AVG(PRES_ART_DIASTOLICA)"
          },
          {
            "name": "prom_sist_anterior",
            "expr": "AVG(SIST_ANTERIOR)"
          },
          {
            "name": "prom_diast_anterior",
            "expr": "AVG(DIAST_ANTERIOR)"
          },
          {
            "name": "suma_costo_medicamentos",
            "expr": "SUM(COSTO_TOTAL_MEDICAMENTOS)"
          },
          {
            "name": "suma_costo_insumos",
            "expr": "SUM(COSTO_TOTAL_INSUMOS)"
          },
          {
            "name": "costo_total",
            "expr": "SUM(COSTO_TOTAL_MEDICAMENTOS + COSTO_TOTAL_INSUMOS)"
          },
          {
            "name": "costo_prom_por_paciente",
            "expr": "MEASURE(costo_total) / MEASURE(total_pacientes)"
          },
          {
            "name": "count_registros",
            "expr": "COUNT(*)"
          }
        ]
      }
    }
  ],
